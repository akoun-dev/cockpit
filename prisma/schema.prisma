generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id            String   @id @default(cuid())
  email         String   @unique
  name          String
  matricule     String?  @unique // Identifiant ANSUT
  fonction      String?  // Poste: Directeur Général, Chef de Département, etc.
  password      String   @default("ansut2025")
  avatar        String?
  isActive      Boolean  @default(true)
  isLocked      Boolean  @default(false)
  mustChangePassword Boolean @default(false)
  failedAttempts Int      @default(0)
  lastLogin     DateTime?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  roleId        String?
  role          Role?    @relation(fields: [roleId], references: [id])
  departmentId  String?
  department    Department? @relation(fields: [departmentId], references: [id])
  auditLogs     AuditLog[]
}

model Role {
  id          String   @id @default(cuid())
  name        String   @unique
  label       String
  description String?
  level       Int      @default(0)
  color       String   @default("#1c55a3")
  isSystem    Boolean  @default(false)
  permissionsJson String? @default("{}") // Granular JSON permissions
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  users        User[]
  permissions  Permission[]
}

model Permission {
  id        String   @id @default(cuid())
  roleId    String
  role      Role     @relation(fields: [roleId], references: [id], onDelete: Cascade)
  module    String
  access    String   @default("read")
  createdAt DateTime @default(now())

  @@unique([roleId, module])
}

model Department {
  id        String   @id @default(cuid())
  name      String   @unique
  code      String?
  headName  String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  indicators      Indicator[]
  indicatorValues IndicatorValue[]
  projects        Project[]
  users           User[]
}

model Indicator {
  id           String   @id @default(cuid())
  name         String
  code         String   @unique
  description  String?
  domain       String
  subDomain    String?
  unit         String   @default("%")
  targetValue  Float?
  alertValue   Float?   // Seuil alerte
  criticalValue Float?  // Seuil critique
  formula      String?
  frequency    String   @default("mensuel")
  sourceSystem String   @default("manuel")
  departmentId String?
  department   Department? @relation(fields: [departmentId], references: [id])
  order        Int      @default(0)
  isActive     Boolean  @default(true)
  isPriority   Boolean  @default(false) // Lot 1 — KPI prioritaire pour le DG
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  values IndicatorValue[]
}

model IndicatorValue {
  id           String   @id @default(cuid())
  indicatorId  String
  indicator    Indicator @relation(fields: [indicatorId], references: [id], onDelete: Cascade)
  value        Float
  period       String
  year         Int
  month        Int?
  quarter      Int?
  departmentId String?
  department   Department? @relation(fields: [departmentId], references: [id])
  comment      String?
  createdAt    DateTime @default(now())

  @@unique([indicatorId, period, departmentId])
}

model Project {
  id          String   @id @default(cuid())
  name        String
  code        String   @unique
  description String?
  status      String   @default("en_cours")
  priority    String   @default("moyenne")
  startDate   DateTime?
  endDate     DateTime?
  budgetPlan  Float?
  budgetReal  Float?
  progress    Float    @default(0)
  departmentId String?
  department  Department? @relation(fields: [departmentId], references: [id])
  manager     String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model AuditLog {
  id        String   @id @default(cuid())
  action    String
  category  String   @default("general")
  userId    String?
  user      User?    @relation(fields: [userId], references: [id])
  details   String?
  ipAddress String?
  createdAt DateTime @default(now())
}

model DataSource {
  id          String   @id @default(cuid())
  module      String
  name        String
  type        String   @default("manuel")
  host        String?
  port        Int?
  endpoint    String?
  database    String?
  username    String?
  password    String?
  description String?
  status      String   @default("actif")
  lastSync    DateTime?
  refreshFreq String   @default("manuel")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  syncLogs    SyncLog[]
}

// ─── NEW MODELS ───────────────────────────────────────────────────

model SyncLog {
  id           String     @id @default(cuid())
  dataSourceId String
  dataSource   DataSource @relation(fields: [dataSourceId], references: [id], onDelete: Cascade)
  status       String     @default("success") // success, warning, error
  recordsSynced Int       @default(0)
  errorMessage String?
  duration     Int        @default(0) // ms
  startedAt    DateTime
  completedAt  DateTime?
  createdAt    DateTime    @default(now())

  @@index([dataSourceId])
}

model Document {
  id          String   @id @default(cuid())
  name        String
  url         String
  type        String   @default("lien") // lien, sharepoint, onedrive, teams
  module      String
  description String?
  visibility  String   @default("all") // all, or comma-separated role names: "DG,DFC,PMO"
  createdBy   String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Alert {
  id          String   @id @default(cuid())
  type        String   @default("kpi") // kpi, technique, securite
  severity    String   @default("info") // info, warning, critical
  title       String
  message     String
  source      String?  // indicator code, data source name, etc.
  isRead      Boolean  @default(false)
  isResolved  Boolean  @default(false)
  resolvedBy  String?
  resolvedAt  DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([type])
  @@index([severity])
  @@index([isRead])
}

model NotificationConfig {
  id               String   @id @default(cuid())
  type             String   @unique // kpi_critique, rapport_genere, sync_echouee, utilisateur_cree
  label            String
  enabled          Boolean  @default(true)
  channel          String   @default("email") // email, in_app, both
  recipients       String   @default("[]") // JSON array of emails or user IDs
  smtpHost         String?  // SMTP config
  smtpPort         Int?
  smtpEncryption   String?  // TLS, SSL, none
  smtpUser         String?
  smtpPassword     String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}
