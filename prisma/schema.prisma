generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id            String   @id @default(cuid())
  email         String   @unique
  name          String
  password      String   @default("ansut2025") // hashed in prod, plain for demo
  avatar        String?
  isActive      Boolean  @default(true)
  lastLogin     DateTime?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  roleId        String?
  role          Role?    @relation(fields: [roleId], references: [id])
  departmentId  String?
  department    Department? @relation(fields: [departmentId], references: [id])
  auditLogs     AuditLog[]
}

model Role {
  id          String   @id @default(cuid())
  name        String   @unique
  label       String   // Display name: "Directeur Général", "Chef de Département"
  description String?
  level       Int      @default(0) // hierarchy level: 100=DG, 80=CT, 60=DFC, 40=PMO, 20=Chef, 10=Agent
  color       String   @default("#1c55a3")
  isSystem    Boolean  @default(false) // system roles can't be deleted
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  users        User[]
  permissions  Permission[]
}

model Permission {
  id        String   @id @default(cuid())
  roleId    String
  role      Role     @relation(fields: [roleId], references: [id], onDelete: Cascade)
  module    String   // accueil, governance, finance, operational, rh, risque, pta, admin
  access    String   @default("read") // none, read, write, admin
  createdAt DateTime @default(now())

  @@unique([roleId, module])
}

model Department {
  id        String   @id @default(cuid())
  name      String   @unique
  code      String?
  headName  String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  indicators      Indicator[]
  indicatorValues IndicatorValue[]
  projects        Project[]
  users           User[]
}

model Indicator {
  id           String   @id @default(cuid())
  name         String
  code         String   @unique
  description  String?
  domain       String
  subDomain    String?
  unit         String   @default("%")
  targetValue  Float?
  formula      String?
  frequency    String   @default("mensuel")
  sourceSystem String   @default("manuel")
  departmentId String?
  department   Department? @relation(fields: [departmentId], references: [id])
  order        Int      @default(0)
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  values IndicatorValue[]
}

model IndicatorValue {
  id           String   @id @default(cuid())
  indicatorId  String
  indicator    Indicator @relation(fields: [indicatorId], references: [id], onDelete: Cascade)
  value        Float
  period       String
  year         Int
  month        Int?
  quarter      Int?
  departmentId String?
  department   Department? @relation(fields: [departmentId], references: [id])
  comment      String?
  createdAt    DateTime @default(now())

  @@unique([indicatorId, period, departmentId])
}

model Project {
  id          String   @id @default(cuid())
  name        String
  code        String   @unique
  description String?
  status      String   @default("en_cours")
  priority    String   @default("moyenne")
  startDate   DateTime?
  endDate     DateTime?
  budgetPlan  Float?
  budgetReal  Float?
  progress    Float    @default(0)
  departmentId String?
  department  Department? @relation(fields: [departmentId], references: [id])
  manager     String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model AuditLog {
  id        String   @id @default(cuid())
  action    String   // LOGIN, LOGOUT, CREATE_USER, UPDATE_USER, DELETE_USER, CREATE_ROLE, UPDATE_ROLE, DELETE_ROLE, UPDATE_PERMISSION, EXPORT_DATA
  category  String   @default("general") // auth, user, role, permission, data, export
  userId    String?
  user      User?    @relation(fields: [userId], references: [id])
  details   String?
  ipAddress String?
  createdAt DateTime @default(now())
}
